<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ══════════════════════ Header ══════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧠 Emotion Detector"
            android:textColor="#E8E8FF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Multimodal · On-Device · TFLite"
            android:textColor="#9090BB"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingBottom="20dp" />

        <!-- ══════════════════════ Text Input Card ══════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝  Text Input"
                    android:textColor="#BB86FC"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <EditText
                    android:id="@+id/etTextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Type how you feel (e.g. I am very happy today)"
                    android:textColorHint="#606080"
                    android:textColor="#E8E8FF"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:minLines="2"
                    android:maxLines="4"
                    android:inputType="textMultiLine|textCapSentences"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnAnalyzeText"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="Analyse Text Only"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#7B2FBE"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════ Audio Input Card ══════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎙  Audio Input"
                    android:textColor="#03DAC6"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/btnStartRecording"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="▶ Record"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#018786"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnStopRecording"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="■ Stop"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#B00020"
                        android:textStyle="bold"
                        android:textSize="13sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnAnalyzeAudio"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Analyse Audio Only"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#018786"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════ Fused Analyse Button ══════════════════════ -->
        <Button
            android:id="@+id/btnAnalyzeAll"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="16dp"
            android:text="⚡  Analyse All (Fused)"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5E35B1"
            android:textStyle="bold"
            android:textSize="15sp" />

        <!-- ══════════════════════ Progress + Status ══════════════════════ -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:indeterminateTint="#BB86FC"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready"
            android:textColor="#9090BB"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- ══════════════════════ Results Section ══════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Results"
                android:textColor="#E8E8FF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="10dp" />

            <!-- Text Result -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTextResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                app:cardBackgroundColor="#1E1030"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝 Text Analysis"
                        android:textColor="#BB86FC"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:paddingBottom="6dp" />

                    <TextView
                        android:id="@+id/tvTextEmotion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Emotion: —"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTextConfidence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Confidence: —"
                        android:textColor="#BBBBDD"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Audio Result -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAudioResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                app:cardBackgroundColor="#0A2020"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎙 Audio Analysis"
                        android:textColor="#03DAC6"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:paddingBottom="6dp" />

                    <TextView
                        android:id="@+id/tvAudioEmotion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Emotion: —"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAudioConfidence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Confidence: —"
                        android:textColor="#BBBBDD"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Fused Result -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFusedResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                app:cardBackgroundColor="#1A0A30"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Fused Prediction"
                        android:textColor="#FFD700"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:id="@+id/tvFusedEmotion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Final Emotion: —"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvFusedInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#CCCCEE"
                        android:textSize="13sp"
                        android:paddingTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
